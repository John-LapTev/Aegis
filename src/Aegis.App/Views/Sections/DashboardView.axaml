<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Aegis.App.ViewModels"
             x:Class="Aegis.App.Views.Sections.DashboardView"
             x:DataType="vm:MainWindowViewModel">
    <!-- Раздел «Дашборд» (плитки-переходы) — вынесен из MainWindow.axaml. DataContext = MainWindowViewModel. -->
    <Grid RowDefinitions="Auto,*" Margin="28,22">
        <StackPanel Grid.Row="0">
            <TextBlock Text="Дашборд" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Быстрый доступ к разделам программы." Margin="0,6,0,16" FontSize="13"
                       TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel DataContext="{Binding Dashboard}" MaxWidth="960">
                <Button Classes="dashtile" Command="{Binding GoScansCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=scan, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource AccentSolidBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Сканирование" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Проверить систему по разделам" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoHealthCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=health, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource OkBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Здоровье" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Температуры, диски, память, батарея" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoTestsCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=cpu, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource AccentSolidBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Тесты" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Проверка под нагрузкой" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoUninstallCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=trash, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource AccentSolidBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Удаление программ" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Удалить программу с чисткой остатков" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoOptimizeCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=bolt, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource AccentSolidBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Оптимизация" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Освободить память от фоновых процессов" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoCompareCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=shield, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource OkBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Сравнить состояние" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Что Aegis сделал для компьютера" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Classes="dashtile" Command="{Binding GoForceDeleteCommand}">
                    <StackPanel Spacing="10">
                        <Path Data="{Binding Source=file, Converter={StaticResource IconGeometry}}" Width="34" Height="34"
                              Stroke="{StaticResource AccentSolidBrush}" StrokeThickness="1.8" Stretch="Uniform" HorizontalAlignment="Center" />
                        <TextBlock Text="Удалить файл" FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,11,0,-2" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Файл/папку, которые не удаляются" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
