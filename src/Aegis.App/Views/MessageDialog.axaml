<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Aegis.App.Views.MessageDialog"
        Title="Aegis" Width="500" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgBaseBrush}"
        FontFamily="Segoe UI, Inter, sans-serif">
    <StackPanel Margin="26,22">
        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
        <TextBlock x:Name="MessageText" Margin="0,12,0,0" FontSize="14" TextWrapping="Wrap" LineHeight="21"
                   Foreground="{StaticResource TextSecondaryBrush}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button x:Name="ActionButton" Classes="primary" Click="OnAction" Margin="0,0,10,0" />
            <Button Content="Понятно" Classes="secondary" Click="OnClose" />
        </StackPanel>
    </StackPanel>
</Window>
